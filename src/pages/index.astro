---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const projects = [
  {
    title: "フリーゲーム投稿サイト GodotPlayer",
    description: "GodotEngineに対応したブラウザゲーム投稿サイト",
    image: "/godotplayer.webp",
    link: "https://godotplayer.com",
    linkText: "サイトへ",
  },
  {
    title: "ビンゴ大会終了時間シュミレーター",
    description: "宴会とかで使えるツール",
    image: "/bingo.webp",
    link: "https://bingo-time-simulator.vercel.app",
    linkText: "サイトへ",
  },
  {
    title: "PCゲーム Re Painter",
    description: "自分の書いたイラストが必殺技になるアクションミニゲーム",
    image: "/repainter.webp",
    link: "https://store.steampowered.com/app/1096420/Re_Painter",
    linkText: "Steamへ",
  },
  {
    title: "ブラウザで遊べるUnity製ミニゲーム集",
    description: "3分くらい暇つぶしできるものを作ってあります",
    image: "/unityroom.webp",
    link: "https://unityroom.com/users/3cr10wv7fsuxmag8h594",
    linkText: "unityroomへ",
  },
];



const socialLinks = [
  { href: "https://github.com/coffee-r", icon: "/github.svg", alt: "GitHub", label: "GitHub", external: true },
  { href: "https://x.com/plus_marumaru", icon: "/x.svg", alt: "X", label: "X (旧Twitter)", external: true },
  { href: "https://zenn.dev/coffee_r", icon: "/zenn.svg", alt: "Zenn", label: "Zenn", external: true },
  { href: "/resume", label: "レジュメ", external: false },
  { href: "https://docs.google.com/forms/d/e/1FAIpQLSctIthyLIVGrD1l11Rg7yVWX6orzKusDdY9thawqmTLgz5CNQ/viewform?usp=publish-editor", label: "お問い合わせ", external: true },
];
---

<Layout title="こーひーあーる" description="気まぐれITエンジニア こーひーあーるのポートフォリオ">
  <Header />
  <main class="flex-1">
    <!-- Hero -->
    <section class="w-full py-12 md:py-16 lg:py-24">
      <div class="w-full px-4 md:px-6">
        <div class="flex flex-col items-center space-y-4 text-center">
          <img
            src="/avator.webp"
            width="200"
            height="200"
            alt="こーひーあーる"
            class="rounded-full"
          />
          <div class="space-y-2">
            <h1 class="text-3xl font-bold tracking-tighter sm:text-4xl md:text-5xl lg:text-6xl">
              こーひーあーる
            </h1>
            <p class="mx-auto max-w-[700px] text-base-content/60 md:text-xl">
              coffee-r
            </p>
          </div>
        </div>
        <div class="mx-auto max-w-3xl mt-12">
          <div class="card bg-base-100 shadow-sm border border-base-200">
            <div class="card-body">
              <h2 class="card-title">自己紹介</h2>
              <p class="text-base-content/70">
                大学生時代にラテアート作りを嗜んでたところから、「こーひー」を冠した名前にしましたが、最近はコーヒー愛が冷めてあんまり飲んでいないです。
                「あーる」は本名のイニシャルから取っています。
              </p>
              <p class="text-base-content/70">
                小学3年生の頃から毎日タイピングゲームで遊んでいて、キーボードに触れることが当たり前になっていたのもあり、結果的にIT系技術職のお仕事に関わらせてもらってます。
              </p>
              <p class="text-base-content/70">
                「自分らしさ」にモザイクをかけてしまっていて、自分のことをまだうまく説明できないのですが、最近は負けず嫌いで嫉妬しやすい、褒めて欲しい、ある程度上達したら飽きてしまう、タイプの人間だなと感じています。
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mountain photo -->
    <section class="w-full">
      <img
        src="/mountain.webp"
        width="1200"
        height="900"
        alt="登山の風景"
        class="object-cover w-full max-h-screen"
        loading="lazy"
      />
    </section>

    <!-- Projects -->
    <section class="w-full py-12 md:py-24 lg:py-32">
      <div class="w-full px-4 md:px-6">
        <h2 class="text-3xl font-bold text-center mb-12">個人開発したもの</h2>
        <div class="grid gap-6 lg:grid-cols-2 max-w-4xl mx-auto">
          {projects.map((project) => (
            <div class="card bg-base-100 shadow-sm border border-base-200">
              <figure class="aspect-video overflow-hidden rounded-t-2xl">
                <img src={project.image} alt={project.title} class="w-full h-full object-cover" loading="lazy" />
              </figure>
              <div class="card-body">
                <h3 class="card-title">{project.title}</h3>
                <p class="text-base-content/70">{project.description}</p>
                <div class="card-actions mt-2">
                  <a href={project.link} target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">
                    {project.linkText}
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Links -->
    <section class="w-full py-12 md:py-24 lg:py-32">
      <div class="w-full px-4 md:px-6">
        <h2 class="text-3xl font-bold text-center mb-12">リンク</h2>
        <div class="flex justify-center flex-wrap gap-4">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
              class="btn btn-outline gap-2"
            >
              {link.icon && <img src={link.icon} width="20" height="20" alt={link.alt} />}
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
